{
  "functions": {
    "api/download.py":       { "maxDuration": 300 },
    "api/health.py":         { "maxDuration": 10  },
    "api/auth.py":           { "maxDuration": 30  },
    "api/clients.py":        { "maxDuration": 30  },
    "api/webhook_asaas.py":  { "maxDuration": 30  },
    "api/subscribe.py":      { "maxDuration": 30  }
  },
  "routes": [
    { "src": "/api/auth(.*)",         "dest": "/api/auth.py"          },
    { "src": "/api/clients(.*)",      "dest": "/api/clients.py"       },
    { "src": "/api/webhook/asaas",    "dest": "/api/webhook_asaas.py" },
    { "src": "/api/subscribe(.*)",    "dest": "/api/subscribe.py"     },
    { "src": "/api/(.*)",             "dest": "/api/$1"               },
    { "src": "/app",                  "dest": "/app.html"             },
    { "src": "/login",                "dest": "/login.html"           },
    { "src": "/register",             "dest": "/register.html"        },
    { "src": "/(.*)",                 "dest": "/$1"                   }
  ]
}
