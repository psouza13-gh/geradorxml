{
  "functions": {
    "api/download.py":       { "maxDuration": 300 },
    "api/health.py":         { "maxDuration": 10  },
    "api/auth.py":           { "maxDuration": 30  },
    "api/clients.py":        { "maxDuration": 30  },
    "api/webhook_stripe.py": { "maxDuration": 30  },
    "api/subscribe.py":      { "maxDuration": 30  },
    "api/admin.py":          { "maxDuration": 30  },
    "api/public.py":         { "maxDuration": 10  }
  },
  "routes": [
    { "src": "/api/auth(.*)",        "dest": "/api/auth.py"           },
    { "src": "/api/health(.*)",      "dest": "/api/health.py"         },
    { "src": "/api/clients(.*)",     "dest": "/api/clients.py"        },
    { "src": "/api/webhook/stripe",  "dest": "/api/webhook_stripe.py" },
    { "src": "/api/subscribe(.*)",   "dest": "/api/subscribe.py"      },
    { "src": "/api/admin(.*)",       "dest": "/api/admin.py"          },
    { "src": "/api/public(.*)",      "dest": "/api/public.py"         },
    { "src": "/api/(.*)",            "dest": "/api/$1"                },
    { "src": "/app",                 "dest": "/app.html"              },
    { "src": "/admin/login",         "dest": "/admin-login.html"      },
    { "src": "/admin",               "dest": "/admin.html"            },
    { "src": "/login",               "dest": "/login.html"            },
    { "src": "/register",            "dest": "/register.html"         },
    { "src": "/forgot-password",     "dest": "/forgot-password.html"  },
    { "src": "/reset-password",      "dest": "/reset-password.html"   },
    { "src": "/(.*)",                "dest": "/$1"                    }
  ]
}
